GEMINI_API_KEY=your_gemini_api_key_here
QDRANT_URL=your_qdrant_url_here
LLM_MODEL=gemini-3.1-flash-lite-preview

# Data Mapping Configuration (JSON paths for the LLM)
MAPPING_FIELD_NAME="values.name"
MAPPING_FIELD_DESC="values.description"
MAPPING_FIELD_PRICE="values.price"
MAPPING_FIELD_ID="identifier"

# Shop URL Templates (used by build_url() in the backend)
# build_url() prepends SHOP_BASE_URL and replaces {{slug}} / {{query}}.
# --- Next.js flat-URL storefront (current default) ---
SHOP_BASE_URL=http://localhost:3000
SHOP_PRODUCT_TEMPLATE=/{{slug}}
SHOP_CATEGORY_TEMPLATE=/{{slug}}
SHOP_SEARCH_TEMPLATE=/products?search={{query}}
# --- WooCommerce (example) ---
# SHOP_PRODUCT_TEMPLATE=/product/{{slug}}/
# SHOP_CATEGORY_TEMPLATE=/product-category/{{slug}}/
# SHOP_SEARCH_TEMPLATE=/?s={{query}}
